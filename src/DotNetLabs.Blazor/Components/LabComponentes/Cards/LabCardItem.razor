@using DotNetLabs.Shared.Laboratorios;
@using DotNetLabs.Shared.Laboratorios.Extensions;
@using DotNetLabs.Shared.Navegacao;

<article class="lab-card">
    <header class="lab-card__header">
        <span class="lab-card__icon">
            <i class="@Laboratorio.Categoria.Icone()"></i>
        </span>

        <div class="lab-card__title-area">
            <span class="lab-card__eyebrow">@Laboratorio.Categoria.Descricao()</span>
            <h3>@Laboratorio.Titulo</h3>
        </div>
    </header>

    <p class="lab-card__description">
        @Laboratorio.Descricao
    </p>

    <div class="lab-card__divider"></div>

    <div class="lab-card__info">
        <div class="lab-card__info-item">
            <i class="@Laboratorio.Dificuldade.Icone()"></i>
            <strong>Dificuldade:</strong>
            <span>@Laboratorio.Dificuldade</span>
        </div>

        <div class="lab-card__info-item">
            <i class="@Laboratorio.Status.Icone()"></i>
            <strong>Status:</strong>
            <span>@Laboratorio.Status</span>
        </div>

        <div class="lab-card__info-item">
            <i class="bi bi-clock"></i>
            <strong>Tempo estimado:</strong>
            <span>@Laboratorio.TempoEstimado</span>
        </div>
    </div>

    @if (Laboratorio.Contribuidores.Any())
    {
        <div class="lab-card__contributors">
            <span class="lab-card__contributors-icon">
                <i class="bi bi-people"></i>
            </span>

            <div>
                <strong>Contribuidores</strong>
                <p>@string.Join(" • ", Laboratorio.Contribuidores.Take(3).Select(c => c.Nome))</p>
            </div>
        </div>
    }

    <a class="lab-card__action"
             href="@Rotas.Laboratorio(Laboratorio.Id)">
        <span>
            <i class="bi bi-book"></i>
            Abrir laboratório
        </span>

        <i class="bi bi-arrow-right"></i>
    </a>
</article>

@code {
    [Parameter]
    public MetadadosLaboratorio Laboratorio { get; set; } = default!;
}