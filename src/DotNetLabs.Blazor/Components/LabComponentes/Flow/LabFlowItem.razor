@namespace DotNetLabs.Blazor.Components.LabComponentes.Flow

@using DotNetLabs.Blazor.Models.Laboratorios.Enums

<div class="lab-flow-item @ClasseModo">
    <div class="@ClasseCard">
        <div class="lab-flow-card-icone">
            @if (Concluido)
            {
                <i class="bi bi-check-lg"></i>
            }
            else if (!string.IsNullOrWhiteSpace(Icone))
            {
                <i class="@Icone"></i>
            }
            else if (Numero.HasValue)
            {
                <span>@Numero</span>
            }
        </div>

        <span class="lab-flow-card-texto">@Texto</span>
    </div>
</div>

@code {
    [CascadingParameter]
    public ModoLaboratorio ModoAtual { get; set; }

    private string ClasseModo => ModoAtual switch
    {
        ModoLaboratorio.Apresentacao => "modo-apresentacao",
        ModoLaboratorio.Professor => "modo-professor",
        _ => "modo-estudo"
    };

    private string ClasseCard =>
        $"lab-flow-card {(Destacado ? "destacado" : "")} {(Concluido ? "concluido" : "")}";

    [Parameter, EditorRequired]
    public string Texto { get; set; } = string.Empty;

    [Parameter]
    public string? Icone { get; set; }

    [Parameter]
    public int? Numero { get; set; }

    [Parameter]
    public bool Destacado { get; set; }

    [Parameter]
    public bool Concluido { get; set; }
}