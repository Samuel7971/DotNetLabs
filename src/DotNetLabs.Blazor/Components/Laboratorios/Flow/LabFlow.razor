@namespace DotNetLabs.Blazor.Components.Laboratorios.Flow

<section class="lab-flow">
    <div class="lab-flow-header">
        <div class="lab-flow-icone">
            <i class="@Icone"></i>
        </div>

        <div>
            <h3>@Titulo</h3>

            @if (!string.IsNullOrWhiteSpace(Descricao))
            {
                <p>@Descricao</p>
            }
        </div>
    </div>

    <div class="lab-flow-lista">
        @ChildContent
    </div>
</section>

@code {
    [Parameter]
    public string Titulo { get; set; } = "Fluxo";

    [Parameter]
    public string? Descricao { get; set; }

    [Parameter]
    public string Icone { get; set; } = "bi bi-diagram-3";

    [Parameter, EditorRequired]
    public RenderFragment? ChildContent { get; set; }
}