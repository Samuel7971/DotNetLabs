@namespace DotNetLabs.Blazor.Components.Laboratorios.Alerts

@using DotNetLabs.Blazor.Models.Laboratorios.Enums;

<div class="@ClasseAlerta">
    <div class="lab-alert__icon">
        <i class="@Icone"></i>
    </div>

    <div class="lab-alert__content">
        @if (!string.IsNullOrWhiteSpace(Titulo))
        {
            <strong>@Titulo</strong>
        }

        <div>
            @ChildContent
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Titulo { get; set; } = "Dica";

    [Parameter]
    public string Tipo { get; set; } = "info";

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string Icone =>
        Tipo switch
        {
            "success" => "bi bi-check-circle",
            "warning" => "bi bi-exclamation-triangle",
            "danger" => "bi bi-x-octagon",
            "info" => "bi bi-info-circle",
            _ => "bi bi-info-circle"
        };

    [CascadingParameter]
    public ModoLaboratorio ModoAtual { get; set; } = ModoLaboratorio.Estudo;

    private string ClasseModo => ModoAtual switch
    {
        ModoLaboratorio.Apresentacao => "lab-alert lab-alert--presentation",
        _ => "lab-alert"
    };

    private string ClasseAlerta => $"{ClasseModo} lab-alert--{Tipo}";
}