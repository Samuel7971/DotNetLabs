@using DotNetLabs.Blazor.Components.Layout
@inherits LayoutComponentBase

<div class="page dl-app-shell">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <main class="dl-main">
        <header class="dl-topbar">
            <div>
                <span class="dl-topbar-kicker">DotNetLabs</span>
                <strong>Aprendizado prático em .NET</strong>
            </div>

            <div class="dl-topbar-actions">
                <span class="dl-topbar-pill">🔥 Sprint UI/UX</span>
                <span class="dl-topbar-pill">🧪 Trilha .NET</span>
            </div>
        </header>

        <article class="dl-page-content">
            @Body

            <Footer />
        </article>
    </main>
</div>