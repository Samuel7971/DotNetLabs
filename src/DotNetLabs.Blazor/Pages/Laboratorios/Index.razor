@page "/laboratorios"

@using DotNetLabs.Blazor.Components.Laboratorios.Cards
@using DotNetLabs.Shared.Laboratorios;

<PageTitle>Laboratórios</PageTitle>

<section class="catalog-hero">
    <div class="catalog-hero__badge">
        🧪 Catálogo de laboratórios
    </div>

    <h1>Aprenda .NET construindo na prática.</h1>

    <p>
        Escolha um laboratório, acompanhe o fluxo, veja o código e entenda o comportamento real por trás dos recursos do .NET.
    </p>
</section>

<section class="catalog-toolbar">
    <div>
        <span class="catalog-toolbar__label">Laboratórios disponíveis</span>
        <strong>@laboratorios.Count</strong>
    </div>

    <span class="catalog-toolbar__status">Primeira trilha em construção</span>
</section>

<section class="catalog-grid">
    @foreach (var laboratorio in laboratorios)
    {
        <LabCardItem Laboratorio="laboratorio" />
    }
</section>

@code {
    private readonly IReadOnlyList<MetadadosLaboratorio> laboratorios = CatalogoLaboratorios.ObterTodos();
}