@page "/laboratorios-teste/cancellation-token"

@using DotNetLabs.Blazor.Components.Laboratorios.Layout
@using DotNetLabs.Blazor.Components.Laboratorios.Blocos
@using DotNetLabs.Blazor.Components.Laboratorios.Alerts
@using DotNetLabs.Blazor.Components.Laboratorios.Code

<LabLayout Titulo="CancellationToken"
           Descricao="Entenda como cancelar operações assíncronas em aplicações .NET de forma segura e elegante."
           Categoria=".NET"
           Nivel="Intermediário"
           TempoEstimado="25 min">

    <LabBloco Titulo="Introdução"
              Label="Primeiro passo"
              Icone="bi bi-book"
              Cor="primary">

        <p>
            Neste laboratório vamos conhecer o <strong>CancellationToken</strong> e entender
            por que ele é uma das principais formas de cancelamento cooperativo no .NET.
        </p>

    </LabBloco>

    <LabBloco Titulo="Teoria"
              Label="Entendendo o conceito"
              Icone="bi bi-lightbulb"
              Cor="warning">

        <p>
            O CancellationToken permite que uma operação assíncrona seja interrompida de forma
            segura quando não faz mais sentido continuar sua execução.
        </p>

    </LabBloco>

    <LabBloco Titulo="Demonstração"
              Label="Veja funcionando"
              Icone="bi bi-play-circle"
              Cor="purple">

        <p>
            Nesta etapa veremos uma requisição sendo cancelada pelo usuário antes de sua conclusão.
        </p>

    </LabBloco>

    <LabBloco Titulo="Código"
              Label="Mão na massa"
              Icone="bi bi-code-slash"
              Cor="success">

        <LabAlert Tipo="info">
            Esse exemplo utiliza <strong>Task.Delay</strong> apenas para simular uma operação longa.
        </LabAlert>


        <LabCodeBlock Titulo="Exemplo básico"
                      Language="C#">

            await Task.Delay(5000, cancellationToken);

            cancellationToken.ThrowIfCancellationRequested();

        </LabCodeBlock>

        <LabAlert Tipo="warning">
            Nunca ignore o <strong>CancellationToken</strong> em operações que podem demorar vários segundos.
        </LabAlert>

    </LabBloco>

    <LabBloco Titulo="Desafio"
              Label="Sua vez"
              Icone="bi bi-trophy"
              Cor="danger">

        <p>
            Adicione um botão de cancelar e faça uma operação respeitar o CancellationToken.
        </p>

    </LabBloco>

    <LabBloco Titulo="Resumo"
              Label="Recapitulando"
              Icone="bi bi-check-circle"
              Cor="info">

        <ul>
            <li>✔ Cancelamento cooperativo.</li>
            <li>✔ Não interrompe a Thread.</li>
            <li>✔ Deve ser propagado entre as camadas.</li>
        </ul>

    </LabBloco>

</LabLayout>
