    private int _segundos = 10;

    private string TextoBotaoIniciar =>
        _executando ? "Executando..." : "Iniciar";
    
    private string IconeBotaoIniciar =>
        _executando ? "bi bi-hourglass-split" : "bi bi-play-fill";

    #region .: Integração API :.
    private CancellationTokenSource? _cts;
    private bool _executando;
    
    private string _status = "Pronto";
    private string _tempo = "00:00:00";
    
    private DateTime? _inicioExecucao;
    
    private List<LabDemoLogItem> _logs = [];
    
    private async Task IniciarAsync()
    {
        _cts?.Dispose();
        _cts = new CancellationTokenSource();
    
        _executando = true;
        _status = "Executando";
        _tempo = "00:00:00";
        _inicioExecucao = DateTime.Now;
        _ = AtualizarCronometroAsync(_cts.Token);
        _logs.Clear();
    
        try
        {
            var resultado = await CancellationTokenLabRunner.ExecutarAsync(
                segundos: _segundos,
                logs: _logs,
                cancellationToken: _cts.Token);
    
            _status = resultado?.Status ?? "Finalizado";
        }
        catch (OperationCanceledException)
        {
            _status = "Cancelado";
    
            AdicionarLog(
                "Operação cancelada pelo usuário no Blazor.",
                "bi bi-x-circle");
        }
        catch (Exception ex)
        {
            _status = "Erro";
    
            AdicionarLog(
                $"Erro inesperado: {ex.Message}",
                "bi bi-exclamation-triangle");
        }
        finally
        {
            _executando = false;
            AtualizarTempo();
        }
    }
    
    private void Cancelar()
    {
        if (_cts is null || !_executando)
            return;
    
        AdicionarLog("Solicitação de cancelamento enviada.", "bi bi-stop-circle");
    
        _cts.Cancel();
    }
    
    private void Limpar()
    {
        _status = "Pronto";
        _tempo = "00:00:00";
        _logs.Clear();
        _inicioExecucao = null;
    }
    
    private void AdicionarLog(string mensagem, string icone)
    {
        _logs.Add(new LabDemoLogItem
        {
            Horario = DateTime.Now,
            Mensagem = mensagem,
            Icone = icone
        });
    }
    
    private void AtualizarTempo()
    {
        if (_inicioExecucao is null)
            return;
    
        var tempo = DateTime.Now - _inicioExecucao.Value;
    
        _tempo = tempo.ToString(@"hh\:mm\:ss");
    }

    private async Task AtualizarCronometroAsync(System.Threading.CancellationToken cancellationToken)
    {
        while (!cancellationToken.IsCancellationRequested && _executando)
        {
            AtualizarTempo();
            await InvokeAsync(StateHasChanged);
    
            try
            {
                await Task.Delay(1000, cancellationToken);
            }
            catch (OperationCanceledException)
            {
                break;
            }
        }
    }
    #endregion
