@page "/laboratorios/{id}"

@using DotNetLabs.Shared.Laboratorios;
@using DotNetLabs.Blazor.Components.Laboratorios.Layout;
@using DotNetLabs.Blazor.Components.Laboratorios.Blocos;
@using DotNetLabs.Blazor.Components.Laboratorios.Alerts;
@using DotNetLabs.Blazor.Components.Laboratorios.Code;
@using DotNetLabs.Blazor.Components.Laboratorios.Mode;
@using DotNetLabs.Blazor.Models.Laboratorios.Enums;
@using DotNetLabs.Blazor.Components.Laboratorios.Professor;
@using DotNetLabs.Blazor.Components.Laboratorios.Hints;

<PageTitle>@laboratorio?.Titulo</PageTitle>

@if (laboratorio is null)
{
    <h1>Laboratório não encontrado</h1>

    <p>O laboratório informado não existe no catálogo.</p>

    <a href="/laboratorio" class="btn btn-secondary">
        Voltar para laboratórios
    </a>
}
else
{
    <LabLayout Titulo="@laboratorio.Titulo"
               Descricao="@laboratorio.Descricao"
               Categoria=".NET"
               Nivel="@laboratorio.Dificuldade.ToString()"
               TempoEstimado="@laboratorio.TempoEstimado">

        <LabModeSelector @bind-ModoAtual="modoAtual" />

        <LabModeProvider ModoAtual="modoAtual">

            <LabBloco Titulo="Introdução"
                      Label="Primeiro passo"
                      Icone="bi bi-book"
                      Cor="primary">

                <p>
                    Este laboratório faz parte da jornada prática do DotNetLabs.
                </p>

            </LabBloco>

            <LabBloco Titulo="Teoria"
                      Label="Entendendo o conceito"
                      Icone="bi bi-lightbulb"
                      Cor="warning">

                <p>
                    Aqui entraremos na explicação conceitual do laboratório.
                </p>

                <LabProfessorNote>
                    Explique este conceito com um exemplo do dia a dia antes de mostrar o código.
                </LabProfessorNote>

                <LabHint>
                    Uma boa forma de explicar é comparar o CancellationToken com um botão de cancelar.
                </LabHint>

            </LabBloco>

            <LabBloco Titulo="Código"
                      Label="Mão na massa"
                      Icone="bi bi-code-slash"
                      Cor="success">

                <LabAlert Tipo="info">
                    Em breve este bloco terá exemplos específicos deste laboratório.
                </LabAlert>

                <LabCodeBlock Titulo="Exemplo inicial"
                              Language="C#"
                              Code="Console.WriteLine("DotNetLabs")"/>

            </LabBloco>

            <LabBloco Titulo="Desafio"
                      Label="Sua vez"
                      Icone="bi bi-trophy"
                      Cor="danger">

                <p>
                    Em breve teremos um desafio prático para este laboratório.
                </p>

            </LabBloco>

            <LabBloco Titulo="Resumo"
                      Label="Recapitulando"
                      Icone="bi bi-check-circle"
                      Cor="info">

                <ul>
                    <li>✔ Conceito principal.</li>
                    <li>✔ Exemplo prático.</li>
                    <li>✔ Desafio para fixação.</li>
                </ul>

            </LabBloco>

        </LabModeProvider>

        <a href="/laboratorios" class="btn btn-secondary mt-3">
            Voltar para laboratórios
        </a>

    </LabLayout>
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private MetadadosLaboratorio? laboratorio;

    protected override void OnParametersSet()
    {
        laboratorio = CatalogoLaboratorios.ObterPorId(Id);
    }

    private ModoLaboratorio modoAtual = ModoLaboratorio.Estudo;
}
