@page "/documentacao"
@using DotNetLabs.Shared.Documentacao
@using DotNetLabs.Shared.Enums

<PageTitle>Documentação | DotNetLabs</PageTitle>

<div class="docs-page">

    <section class="docs-hero">

        <div class="docs-hero-content">

            <span class="docs-eyebrow">
                <i class="bi bi-journals"></i>
                Central de conhecimento
            </span>

            <h1>
                Conhecimento organizado para
                <span>todo o time.</span>
            </h1>

            <p>
                Encontre documentações técnicas, funcionais e de negócio em um único
                lugar. Um espaço criado para preservar experiências, compartilhar
                aprendizados e facilitar a colaboração entre diferentes áreas.
            </p>

            <div class="docs-search">
                <i class="bi bi-search"></i>

                <input type="text"
                       placeholder="Buscar na documentação..."
                       disabled />

                <span>Em breve</span>
            </div>

        </div>

        <div class="docs-hero-visual">

            <div class="docs-visual-card">

                <div class="docs-visual-header">
                    <span class="docs-visual-icon">
                        <i class="bi bi-book"></i>
                    </span>

                    <span class="docs-visual-badge">
                        DotNetLabs Docs
                    </span>
                </div>

                <h2>
                    Conhecimento compartilhado vira patrimônio do time.
                </h2>

                <p>
                    Documentar é garantir que boas ideias, regras importantes e
                    experiências não fiquem presas apenas na memória das pessoas.
                </p>

                <div class="docs-visual-items">
                    <span>
                        <i class="bi bi-check-circle-fill"></i>
                        Conteúdo organizado
                    </span>

                    <span>
                        <i class="bi bi-check-circle-fill"></i>
                        Consulta rápida
                    </span>

                    <span>
                        <i class="bi bi-check-circle-fill"></i>
                        Colaboração entre áreas
                    </span>
                </div>

            </div>

        </div>

    </section>

    <section class="docs-section">

        <div class="docs-section-heading">

            <div>
                <span class="docs-section-label">Categorias</span>

                <h2>Explore a documentação</h2>

