        <div class="docs-category-grid">

            <a class="docs-category-card docs-category-card-featured"
               href="/documentacao/dotnetlabs">

                <div class="docs-category-top">

                    <span class="docs-category-icon">
                        <i class="bi bi-bezier2"></i>
                    </span>

                    <span class="docs-category-status">
                        Disponível
                    </span>

                </div>

                <div class="docs-category-content">

                    <span class="docs-category-area">Plataforma</span>

                    <h3>DotNetLabs</h3>

                    <p>
                        Visão da plataforma, arquitetura, padrões, decisões e guias
                        para contribuição.
                    </p>

                </div>

                <div class="docs-category-footer">

                    <span>
                        <i class="bi bi-file-earmark-text"></i>
                        @ObterTextoQuantidade(CategoriaDocumento.DotNetLabs)
