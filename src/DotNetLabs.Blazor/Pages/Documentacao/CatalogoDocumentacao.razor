                    <strong>
                        Explorar
                        <i class="bi bi-arrow-right"></i>
                    </strong>

                </div>

            </a>

            <article class="docs-category-card docs-category-card-disabled">

                <div class="docs-category-top">

                    <span class="docs-category-icon">
                        <i class="bi bi-code-square"></i>
                    </span>

                    <span class="docs-category-status">
                        Em breve
                    </span>

                </div>

                <div class="docs-category-content">

                    <span class="docs-category-area">Engenharia</span>

